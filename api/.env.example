DATABASE_URL=postgresql+psycopg://skillful:skillful@localhost:5432/skillful_marketplace

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-real-environments-please-use-a-long-random-value

# Optional: how long an access token stays valid for, in minutes. Defaults to 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Stripe (required for checkout)
STRIPE_SECRET_KEY=sk_test_...
# Obtained from `stripe listen --forward-to localhost:8000/checkout/webhook` during local dev
STRIPE_WEBHOOK_SECRET=whsec_...
